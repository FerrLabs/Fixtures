{
  "meta": {
    "name": "orphaned-tag-strategy",
    "description": "Orphaned tags (not on default branch) are handled according to strategy",
    "default_branch": "main"
  },
  "config": {
    "content": "{ \"orphaned_tag_strategy\": \"ignore\", \"package\": [ { \"name\": \"app\", \"path\": \".\", \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}] } ] }"
  },
  "packages": [
    { "name": "app", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat: new feature", "files": ["src/main.rs"] }
  ],
  "tags": [
    { "name": "v1.0.1-orphan", "at_commit": -1 }
  ],
  "expect": {
    "check_contains": ["app"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
