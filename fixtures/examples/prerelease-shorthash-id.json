{
  "meta": {
    "name": "prerelease-shorthash-id",
    "description": "Pre-release with short commit hash as identifier",
    "default_branch": "main"
  },
  "config": {
    "content": "{ \"branches\": [ { \"pattern\": \"dev\", \"channel\": \"dev\", \"prerelease_identifier\": \"short-hash\" } ], \"package\": [ { \"name\": \"app\", \"path\": \".\", \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}] } ] }"
  },
  "packages": [
    { "name": "app", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat: add hash prerelease", "files": ["src/main.rs"] }
  ],
  "branches": [
    {
      "name": "dev",
      "at_commit": -1,
      "commits": [
        { "message": "feat: dev feature", "files": ["src/dev.rs"] }
      ]
    }
  ],
  "expect": {
    "check_contains": ["app", "dev"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
