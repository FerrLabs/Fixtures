{
  "meta": {
    "name": "calver-basic",
    "description": "Calendar-based versioning produces date-based version numbers",
    "default_branch": "main"
  },
  "config": {
    "content": "{ \"versioning\": \"calver\", \"package\": [ { \"name\": \"app\", \"path\": \".\", \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}] } ] }"
  },
  "packages": [
    { "name": "app", "path": ".", "initial_version": "2026.1.0", "tag": "v2026.1.0" }
