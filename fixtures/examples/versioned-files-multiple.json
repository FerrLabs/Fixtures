{
  "meta": {
    "name": "versioned-files-multiple",
    "description": "Package with multiple versioned files (Cargo.toml and package.json) gets both updated",
    "default_branch": "main"
  },
  "config": {
    "content": "{ \"package\": [ { \"name\": \"lib\", \"path\": \".\", \"versioned_files\": [{\"path\": \"Cargo.toml\", \"format\": \"toml\"}, {\"path\": \"package.json\", \"format\": \"json\"}] } ] }"
  },
  "packages": [
    { "name": "lib", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat: add multi-format support", "files": ["src/lib.rs"] }
  ],
  "expect": {
    "check_contains": ["lib", "1.1.0"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
