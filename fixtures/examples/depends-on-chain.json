{
  "meta": {
    "name": "depends-on-chain",
    "description": "Package B depends on A — bumping A triggers a bump of B",
    "default_branch": "main"
  },
  "config": {
    "content": "{ \"package\": [ { \"name\": \"core\", \"path\": \"core\", \"versioned_files\": [{\"path\": \"core/version.toml\", \"format\": \"toml\"}] }, { \"name\": \"cli\", \"path\": \"cli\", \"versioned_files\": [{\"path\": \"cli/version.toml\", \"format\": \"toml\"}], \"dependsOn\": [\"core\"] } ] }"
  },
  "packages": [
    { "name": "core", "path": "core", "initial_version": "0.1.0", "tag": "core@v0.1.0" },
    { "name": "cli", "path": "cli", "initial_version": "0.1.0", "tag": "cli@v0.1.0" }
  ],
  "commits": [
    { "message": "feat(core): add new parser API", "files": ["core/src/parser.rs"] }
  ],
  "expect": {
    "check_contains": ["core", "0.2.0", "cli"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 2
  }
}
