{
  "meta": {
    "name": "sequential-versioning",
    "description": "Sequential versioning increments a single integer (1, 2, 3, ...)",
    "default_branch": "main"
  },
  "config": {
    "content": "{ \"versioning\": \"sequential\", \"package\": [ { \"name\": \"app\", \"path\": \".\", \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}] } ] }"
  },
  "packages": [
    { "name": "app", "path": ".", "initial_version": "5", "tag": "v5" }
  ],
  "commits": [
    { "message": "feat: add new feature", "files": ["src/main.rs"] }
  ],
  "expect": {
    "check_contains": ["app"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
