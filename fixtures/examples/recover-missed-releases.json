{
  "meta": {
    "name": "recover-missed-releases",
    "description": "With recover_missed_releases enabled, skipped versions are caught up",
    "default_branch": "main"
  },
  "config": {
    "content": "{ \"recover_missed_releases\": true, \"package\": [ { \"name\": \"app\", \"path\": \".\", \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}] } ] }"
  },
  "packages": [
    { "name": "app", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat: first feature", "files": ["src/a.rs"] },
    { "message": "feat: second feature", "files": ["src/b.rs"] },
    { "message": "fix: patch fix", "files": ["src/c.rs"] }
  ],
  "expect": {
    "check_contains": ["app"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
