{
  "meta": {
    "name": "prerelease-timestamp-id",
    "description": "Pre-release with timestamp identifier instead of incrementing integer",
    "default_branch": "main"
  },
  "config": {
    "content": "{ \"branches\": [ { \"pattern\": \"beta\", \"channel\": \"beta\", \"prerelease_identifier\": \"timestamp\" } ], \"package\": [ { \"name\": \"app\", \"path\": \".\", \"versioned_files\": [{\"path\": \"version.toml\", \"format\": \"toml\"}] } ] }"
  },
  "packages": [
    { "name": "app", "path": ".", "initial_version": "1.0.0", "tag": "v1.0.0" }
  ],
  "commits": [
    { "message": "feat: add timestamp prerelease", "files": ["src/main.rs"] }
  ],
  "branches": [
    {
      "name": "beta",
      "at_commit": -1,
      "commits": [
        { "message": "feat: beta feature", "files": ["src/beta.rs"] }
      ]
    }
  ],
  "expect": {
    "check_contains": ["app", "beta"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 1
  }
}
