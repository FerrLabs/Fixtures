{
  "meta": {
    "name": "shared-paths",
    "description": "Changes to shared paths trigger bumps in all packages that reference them",
    "default_branch": "main"
  },
  "config": {
    "content": "{ \"package\": [ { \"name\": \"api\", \"path\": \"packages/api\", \"versioned_files\": [{\"path\": \"packages/api/version.toml\", \"format\": \"toml\"}], \"sharedPaths\": [\"packages/shared\"] }, { \"name\": \"web\", \"path\": \"packages/web\", \"versioned_files\": [{\"path\": \"packages/web/version.toml\", \"format\": \"toml\"}], \"sharedPaths\": [\"packages/shared\"] } ] }"
  },
  "packages": [
    { "name": "api", "path": "packages/api", "initial_version": "1.0.0", "tag": "api@v1.0.0" },
    { "name": "web", "path": "packages/web", "initial_version": "1.0.0", "tag": "web@v1.0.0" }
  ],
  "commits": [
    { "message": "feat: add shared utility", "files": ["packages/shared/src/utils.ts"] }
  ],
  "expect": {
    "check_contains": ["api", "web", "1.1.0"],
    "check_not_contains": ["Nothing to release"],
    "packages_released": 2
  }
}
